# Server
APP_PORT=8787
PORT=8787
HOST=0.0.0.0

# DeepSeek model proxy
# 云端部署建议使用服务端统一配置，不要把 API Key 写入前端代码。
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-v4-pro
DEEPSEEK_BASE_URL=https://api.deepseek.com

# Customer-facing controls
# 云端客户试用默认关闭；内部演示需要打开时改为 true 后重新 build。
VITE_ENABLE_TRIAL_RESET=false
VITE_ENABLE_CLIENT_MODEL_CONFIG=false
ALLOW_CLIENT_MODEL_CONFIG=false
